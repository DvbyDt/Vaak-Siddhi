# VaakSiddhi Environment Variables
# ─────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────
# Google Gemini API Key (FREE — NO credit card needed!)
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API Key"
# 3. Copy and paste below
# Free tier: 15 req/min, 1M tokens/day
GEMINI_API_KEY=your-gemini-api-key-here

# ── OPTIONAL ──────────────────────────────────────────
# Backend API URL (for deployed frontend)
# VITE_BACKEND_URL=https://your-backend.railway.app

# Groq API Key (FREE — best primary provider, 14,400 req/day)
# https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Sarvam AI — authentic Indian-language TTS (bulbul:v2) + STT (saarika:v2)
# TTS: replaces browser SpeechSynthesis — actual Sanskrit/Hindi voice quality
# STT: replaces Chrome Web Speech API — far more accurate for Sanskrit phonemes
# Free tier: 50,000 chars/month TTS · 500 min/month STT (no credit card)
# https://console.sarvam.ai
SARVAM_API_KEY=your-sarvam-api-key-here

# Your deployed frontend URL — restricts CORS to only this origin in production.
# Leave empty to allow localhost only.
# FRONTEND_URL=https://vaaksiddhi.vercel.app